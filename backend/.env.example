# Copy this to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ioe_papers
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
